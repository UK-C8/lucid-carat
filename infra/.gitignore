# Terraform state and lock files — never commit
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl
*.tfplan

# Variable files that may contain secrets
*.auto.tfvars
*.tfvars
!example.tfvars

# Crash logs
crash.log
crash.*.log

# Override files (local developer overrides)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

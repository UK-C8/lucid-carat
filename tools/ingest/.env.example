# Copy to .env and fill in real values. Never commit .env.

# Postgres connection — local dev points at lucidcarat_dev
LC_DATABASE_URL=postgresql://urvilkargathala@localhost/lucidcarat_dev

# S3 — for local dev you can use LocalStack or a real dev bucket
LC_S3_BUCKET=lucidcarat-dev-media
LC_S3_REGION=ap-south-1

# AWS credentials — for local dev use a profile or explicit keys
# AWS_PROFILE=lucidcarat-dev
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
